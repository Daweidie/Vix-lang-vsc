{
  "name": "vix",
  "displayName": "Vix Language Support",
  "description": "为 Vix 语言提供核心语言支持，包括语法高亮、智能代码补全（IntelliSense）和实时错误诊断提示",
  "version": "0.0.1",
  "publisher": "vix-team",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:vix"
  ],
  "main": "./out/extension.js",
  "icon": "images/logo.png",
  "contributes": {
    "languages": [{
      "id": "vix",
      "aliases": ["Vix", "vix"],
      "extensions": [".vix"],
      "icon": {
        "light": "images/logo.png",
        "dark": "images/logo.png"
      },
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "vix",
      "scopeName": "source.vix",
      "path": "./syntaxes/vix.json"
    }],
    "commands": [{
      "command": "vix.compile",
      "title": "Compile Vix",
      "icon": "$(play)"
    }, {
      "command": "vix.showCompilerOutput",
      "title": "Vix: Show Compiler Output",
      "icon": "$(output)"
    }, {
      "command": "vix.compile.l0",
      "title": "Compile Vix (l0)"
    }, {
      "command": "vix.compile.l1",
      "title": "Compile Vix (l1)"
    }, {
      "command": "vix.compile.l2",
      "title": "Compile Vix (l2)"
    }, {
      "command": "vix.compile.l3",
      "title": "Compile Vix (l3)"
    }, {
      "command": "vix.compile.asm.l0",
      "title": "Compile Vix to Assembly (l0)"
    }, {
      "command": "vix.compile.asm.l1",
      "title": "Compile Vix to Assembly (l1)"
    }, {
      "command": "vix.compile.asm.l2",
      "title": "Compile Vix to Assembly (l2)"
    }, {
      "command": "vix.compile.asm.l3",
      "title": "Compile Vix to Assembly (l3)"
    }, {
      "command": "vix.compile.obj.l0",
      "title": "Compile Vix to Object File (l0)"
    }, {
      "command": "vix.compile.obj.l1",
      "title": "Compile Vix to Object File (l1)"
    }, {
      "command": "vix.compile.obj.l2",
      "title": "Compile Vix to Object File (l2)"
    }, {
      "command": "vix.compile.obj.l3",
      "title": "Compile Vix to Object File (l3)"
    }],
    "menus": {
      "editor/title": [{
        "command": "vix.compile",
        "when": "resourceLangId == vix",
        "group": "navigation"
      }]
    },
    "configuration": {
      "title": "Vix",
      "properties": {
        "vix.language": {
          "type": "string",
          "enum": [
            "zh-cn",
            "en"
          ],
          "default": "zh-cn",
          "description": "Language for Vix hover/completion/diagnostic prompts (zh-cn or en)."
        },
        "vix.compilerPath": {
          "type": "string",
          "default": "vixc",
          "description": "Path to the vixc compiler executable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.109.0",
    "typescript": "^4.8.0",
    "vscode-test": "^1.6.1"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.1",
    "vscode-languageserver": "^8.0.1",
    "vscode-languageserver-textdocument": "^1.0.4"
  }
}